<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/textTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ConcurrentTranslator"
            android:textColor="#1F2937"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/textSubtitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Traduza textos rapidamente usando tradução concorrente"
            android:textColor="#6B7280"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Texto para tradução"
            android:textColor="#374151"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editTexto"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="#FFFFFF"
            android:gravity="top"
            android:hint="Digite uma palavra ou frase"
            android:inputType="textMultiLine"
            android:minLines="4"
            android:padding="14dp"
            android:textColor="#111827"
            android:textColorHint="#9CA3AF"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Idioma de origem"
            android:textColor="#374151"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerOrigem"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Idioma de destino"
            android:textColor="#374151"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerDestino"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <Button
            android:id="@+id/btnTraduzir"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Traduzir"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginTop="24dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/textResultadoTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Resultado"
            android:textColor="#374151"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp"
            android:background="#FFFFFF"
            android:padding="14dp"
            android:text="A tradução aparecerá aqui."
            android:textColor="#111827"
            android:textSize="17sp" />

    </LinearLayout>

</ScrollView>